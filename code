      line-height: 1.5;
    }

    .location-map-wrap {
      position: relative;
    }
    .location-map-wrap::before {
      content: '';
      position: absolute;
      inset: -8px;
      border: 1px solid rgba(201,168,76,.2);
      pointer-events: none;
      z-index: 1;
    }
    .location-map-wrap::after {
      content: '✦';
      position: absolute;
      bottom: -14px; right: -14px;
      color: var(--gold);
      font-size: .8rem;
      z-index: 2;
    }
    .location-map-wrap iframe {
      width: 100%;
      height: 400px;
      border: none;
      display: block;
      filter: grayscale(20%) sepia(15%);
