<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title> Bhuvana's Drape & Grace — Saree Artistry</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Cinzel:wght@400;500;600&family=Lato:wght@300;400&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --gold: #c9a84c;
      --gold-light: #e8cc80;
      --gold-pale: #f5e9c8;
      --rose: #8b3a52;
      --rose-light: #c4748a;
      --cream: #faf6ef;
      --deep: #1a0f0a;
      --deep2: #2c1810;
      --text: #3a2218;
      --text-light: #7a5c4a;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--cream);
      color: var(--text);
      font-family: 'Lato', sans-serif;
      font-weight: 300;
      overflow-x: hidden;
    }

    /* ── CURSOR ── */
    body { cursor: none; }
    #cursor {
      position: fixed; width: 12px; height: 12px;
      background: var(--gold); border-radius: 50%;
      pointer-events: none; z-index: 9999;
      transform: translate(-50%,-50%);
      transition: width .2s, height .2s, background .2s;
      mix-blend-mode: multiply;
    }
    #cursor-ring {
      position: fixed; width: 36px; height: 36px;
      border: 1px solid var(--gold); border-radius: 50%;
      pointer-events: none; z-index: 9998;
      transform: translate(-50%,-50%);
      transition: transform .12s ease-out, width .3s, height .3s;
    }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--cream); }
    ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 2px; }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; width: 100%; z-index: 100;
      padding: 18px 60px;
      display: flex; align-items: center; justify-content: space-between;
      background: linear-gradient(to bottom, rgba(26,15,10,.85) 0%, transparent 100%);
      backdrop-filter: blur(2px);
      transition: background .4s;
    }
    nav.scrolled { background: rgba(26,15,10,.95); }

    .nav-logo {
      font-family: 'Cinzel', serif;
      font-size: 1.35rem;
      color: var(--gold-light);
      letter-spacing: .18em;
      text-decoration: none;
    }
    .nav-logo span { color: var(--rose-light); font-style: italic; font-family: 'Cormorant Garamond', serif; }

    .nav-links { display: flex; gap: 36px; list-style: none; }
    .nav-links a {
      font-family: 'Cinzel', serif;
      font-size: .72rem; letter-spacing: .2em;
      color: rgba(255,255,255,.75);
      text-decoration: none; text-transform: uppercase;
      position: relative; padding-bottom: 3px;
      transition: color .3s;
    }
    .nav-links a::after {
      content: ''; position: absolute; bottom: 0; left: 0;
      width: 0; height: 1px; background: var(--gold);
      transition: width .35s ease;
    }
    .nav-links a:hover { color: var(--gold-light); }
    .nav-links a:hover::after { width: 100%; }

    /* ── HERO ── */
    #hero {
      position: relative; height: 100vh; min-height: 700px;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, #1a0f0a 0%, #2c1810 40%, #3d1c20 70%, #1a0f0a 100%);
    }

    /* Animated silk shimmer */
    .hero-bg::before {
      content: '';
      position: absolute; inset: -50%;
      background: conic-gradient(from 0deg at 50% 50%,
        transparent 0deg, rgba(201,168,76,.04) 40deg,
        transparent 80deg, rgba(139,58,82,.06) 140deg,
        transparent 180deg, rgba(201,168,76,.05) 220deg,
        transparent 260deg, rgba(139,58,82,.04) 320deg,
        transparent 360deg);
      animation: silkSpin 18s linear infinite;
    }
    @keyframes silkSpin { to { transform: rotate(360deg); } }

    /* Floating petals */
    .petal {
      position: absolute;
      width: 6px; height: 6px;
      background: radial-gradient(circle, var(--gold-light), transparent);
      border-radius: 50% 0 50% 0;
      opacity: 0;
      animation: floatPetal linear infinite;
    }
    @keyframes floatPetal {
      0%   { transform: translateY(110vh) rotate(0deg) scale(0); opacity: 0; }
      10%  { opacity: .6; }
      90%  { opacity: .3; }
      100% { transform: translateY(-10vh) rotate(720deg) scale(1.5); opacity: 0; }
    }

    /* Decorative border lines */
    .hero-border {
      position: absolute; inset: 30px;
      border: 1px solid rgba(201,168,76,.2);
      pointer-events: none;
    }
    .hero-border::before, .hero-border::after {
      content: '✦';
      position: absolute;
      color: var(--gold);
      font-size: .8rem;
    }
    .hero-border::before { top: -8px; left: 50%; transform: translateX(-50%); }
    .hero-border::after  { bottom: -8px; left: 50%; transform: translateX(-50%); }

    /* Corner ornaments */
    .hero-corner {
      position: absolute; width: 50px; height: 50px;
      border-color: var(--gold);
      border-style: solid;
      opacity: .5;
    }
    .hero-corner.tl { top: 42px; left: 42px; border-width: 1px 0 0 1px; }
    .hero-corner.tr { top: 42px; right: 42px; border-width: 1px 1px 0 0; }
    .hero-corner.bl { bottom: 42px; left: 42px; border-width: 0 0 1px 1px; }
    .hero-corner.br { bottom: 42px; right: 42px; border-width: 0 1px 1px 0; }

    .hero-content {
      position: relative; z-index: 2;
      text-align: center;
      animation: heroReveal 1.6s cubic-bezier(.22,1,.36,1) both;
    }
    @keyframes heroReveal {
      from { opacity: 0; transform: translateY(40px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .hero-eyebrow {
      font-family: 'Cinzel', serif;
      font-size: .68rem; letter-spacing: .5em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 22px;
      opacity: 0;
      animation: fadeUp .8s .4s forwards;
    }

    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3.5rem, 8vw, 7rem);
      font-weight: 300;
      line-height: 1.05;
      color: #fff;
      letter-spacing: .03em;
      opacity: 0;
      animation: fadeUp .9s .65s forwards;
    }
    .hero-title em {
      display: block;
      font-style: italic;
      color: var(--gold-light);
      font-size: 1.08em;
    }

    .hero-divider {
      margin: 28px auto;
      width: 120px; height: 1px;
      background: linear-gradient(to right, transparent, var(--gold), transparent);
      opacity: 0;
      animation: fadeUp .7s .9s forwards;
    }

    .hero-sub {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.25rem;
      font-style: italic;
      color: rgba(255,255,255,.65);
      letter-spacing: .08em;
      opacity: 0;
      animation: fadeUp .7s 1.1s forwards;
    }

    .hero-cta {
      margin-top: 42px;
      opacity: 0;
      animation: fadeUp .7s 1.3s forwards;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── SCROLL INDICATOR ── */
    .scroll-hint {
      position: absolute; bottom: 38px; left: 50%;
      transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 8px;
      opacity: .6;
      animation: pulse 2.5s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100%{opacity:.4} 50%{opacity:.8} }
    .scroll-hint span {
      font-family: 'Cinzel', serif; font-size: .6rem;
      letter-spacing: .3em; color: var(--gold-light); text-transform: uppercase;
    }
    .scroll-hint-line {
      width: 1px; height: 50px;
      background: linear-gradient(to bottom, var(--gold-light), transparent);
    }

    /* ── BUTTONS ── */
    .btn-gold {
      display: inline-block;
      font-family: 'Cinzel', serif;
      font-size: .78rem; letter-spacing: .25em;
      text-transform: uppercase;
      color: var(--deep);
      background: linear-gradient(135deg, var(--gold-light), var(--gold));
      padding: 16px 46px;
      border: none; cursor: pointer;
      position: relative; overflow: hidden;
      text-decoration: none;
      transition: transform .3s, box-shadow .3s;
      box-shadow: 0 4px 30px rgba(201,168,76,.3);
    }
    .btn-gold::before {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,.25), transparent);
      transform: translateX(-100%) skewX(-20deg);
      transition: transform .5s ease;
    }
    .btn-gold:hover::before { transform: translateX(200%) skewX(-20deg); }
    .btn-gold:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 40px rgba(201,168,76,.45);
    }

    .btn-outline {
      display: inline-block;
      font-family: 'Cinzel', serif;
      font-size: .78rem; letter-spacing: .25em; text-transform: uppercase;
      color: var(--gold-light);
      border: 1px solid var(--gold);
      padding: 15px 44px;
      background: transparent;
      text-decoration: none;
      position: relative; overflow: hidden;
      transition: color .3s, box-shadow .3s, transform .3s;
    }
    .btn-outline::after {
      content: '';
      position: absolute; inset: 0;
      background: var(--gold);
      transform: scaleX(0); transform-origin: left;
      transition: transform .35s ease;
      z-index: -1;
    }
    .btn-outline:hover { color: var(--deep); transform: translateY(-2px); box-shadow: 0 6px 30px rgba(201,168,76,.2); }
    .btn-outline:hover::after { transform: scaleX(1); }

    /* ── SECTION SHARED ── */
    section { position: relative; }

    .section-label {
      font-family: 'Cinzel', serif;
      font-size: .65rem; letter-spacing: .5em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 14px;
      display: flex; align-items: center; gap: 14px;
    }
    .section-label::before, .section-label::after {
      content: ''; flex: 0 0 40px; height: 1px;
      background: linear-gradient(to right, transparent, var(--gold));
    }
    .section-label::after { background: linear-gradient(to left, transparent, var(--gold)); }

    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.2rem, 4vw, 3.4rem);
      font-weight: 300;
      line-height: 1.2;
      color: var(--deep);
      margin-bottom: 14px;
    }
    .section-title em { font-style: italic; color: var(--rose); }

    .section-desc {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem; font-style: italic;
      color: var(--text-light);
      line-height: 1.8;
      max-width: 520px;
    }

    /* ── REVEAL ANIMATION ── */
    .reveal {
      opacity: 0;
      transform: translateY(35px);
      transition: opacity .8s ease, transform .8s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── MASTERS SECTION ── */
    #masters {
      padding: 110px 60px;
      background: var(--cream);
    }
    .masters-header { text-align: center; margin-bottom: 70px; }

    .masters-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .master-card {
      position: relative;
      overflow: hidden;
      aspect-ratio: 3/4;
      background: linear-gradient(135deg, #2c1810, #1a0f0a);
      cursor: pointer;
    }

    .master-card::before {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(to bottom, transparent 40%, rgba(26,15,10,.9) 100%);
      z-index: 2;
    }

    .master-card-img {
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
      transition: transform .7s cubic-bezier(.25,.46,.45,.94);
      /* Placeholder gradient when no image */
      background: linear-gradient(160deg, #3d1c20 0%, #2c1810 50%, #1a0f0a 100%);
    }

    /* Placeholder shimmer for empty slots */
    .master-card-img.placeholder {
      display: flex; align-items: center; justify-content: center;
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 1.1rem;
      color: rgba(201,168,76,.4);
      letter-spacing: .1em;
    }

    .master-card:hover .master-card-img { transform: scale(1.08); }

    .master-card-info {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 30px 28px;
      z-index: 3;
    }
    .master-card-number {
      font-family: 'Cinzel', serif;
      font-size: .62rem; letter-spacing: .4em;
      color: var(--gold); margin-bottom: 8px;
    }
    .master-card-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem; font-weight: 300;
      color: #fff; line-height: 1.2;
    }

    /* Gold border reveal on hover */
    .master-card::after {
      content: '';
      position: absolute; inset: 0;
      border: 1px solid rgba(201,168,76,0);
      z-index: 4;
      transition: border-color .4s;
    }
    .master-card:hover::after { border-color: rgba(201,168,76,.5); }

    /* ── ABOUT STRIP ── */
    #about {
      padding: 90px 60px;
      background: linear-gradient(135deg, var(--deep) 0%, var(--deep2) 100%);
      display: grid;
      grid-template-columns: 1fr 1px 1fr;
      gap: 60px;
      align-items: center;
    }
    .about-divider { background: rgba(201,168,76,.3); }
    .about-text .section-title { color: var(--cream); }
    .about-text .section-desc { color: rgba(255,255,255,.6); max-width: none; }

    .about-stats {
      display: grid; grid-template-columns: 1fr 1fr; gap: 40px;
    }
    .stat {
      text-align: center;
      padding: 30px 20px;
      border: 1px solid rgba(201,168,76,.15);
      position: relative;
      transition: border-color .3s;
    }
    .stat:hover { border-color: rgba(201,168,76,.4); }
    .stat-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 3rem; font-weight: 300;
      color: var(--gold-light);
      line-height: 1;
    }
    .stat-label {
      font-family: 'Cinzel', serif;
      font-size: .65rem; letter-spacing: .25em;
      color: rgba(255,255,255,.5);
      text-transform: uppercase; margin-top: 8px;
    }

    /* ── OUR WORKS ── */
    #works {
      padding: 110px 60px;
      background: #fdf9f3;
    }
    .works-header { text-align: center; margin-bottom: 80px; }

    .works-tabs {
      display: flex; justify-content: center; gap: 0;
      margin-bottom: 60px;
      border-bottom: 1px solid rgba(201,168,76,.25);
    }
    .works-tab {
      font-family: 'Cinzel', serif;
      font-size: .75rem; letter-spacing: .25em;
      text-transform: uppercase;
      color: var(--text-light);
      padding: 14px 42px;
      cursor: pointer; border: none;
      background: none;
      position: relative;
      transition: color .3s;
    }
    .works-tab::after {
      content: '';
      position: absolute; bottom: -1px; left: 0; right: 0;
      height: 2px; background: var(--gold);
      transform: scaleX(0);
      transition: transform .35s ease;
    }
    .works-tab.active { color: var(--rose); }
    .works-tab.active::after { transform: scaleX(1); }
    .works-tab:hover { color: var(--gold); }

    .works-panel { display: none; }
    .works-panel.active { display: block; }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(2, 320px);
      gap: 18px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .gallery-item {
      position: relative; overflow: hidden;
      cursor: pointer;
      background: linear-gradient(135deg, #2c1810, #1a0f0a);
    }

    /* Special sizing for first item */
    .gallery-item:nth-child(1) {
      grid-row: 1 / 3;
    }

    .gallery-item img {
      width: 100%; height: 100%; object-fit: cover;
      display: block;
      transition: transform .65s cubic-bezier(.25,.46,.45,.94);
    }

    .gallery-item .img-placeholder {
      width: 100%; height: 100%;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 12px;
      background: linear-gradient(160deg, #3d1c20 0%, #2c1810 60%, #1a0f0a 100%);
    }

    .gallery-item .img-placeholder .ph-icon {
      font-size: 2.5rem; opacity: .3;
    }
    .gallery-item .img-placeholder .ph-label {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 1rem;
      color: rgba(201,168,76,.4); letter-spacing: .1em;
    }
    .gallery-item .ph-num {
      font-family: 'Cinzel', serif;
      font-size: .6rem; letter-spacing: .3em;
      color: rgba(201,168,76,.3);
    }

    .gallery-item:hover img { transform: scale(1.1); }

    .gallery-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(26,15,10,.85) 0%, transparent 50%);
      opacity: 0;
      transition: opacity .4s;
      display: flex; align-items: flex-end;
      padding: 28px;
    }
    .gallery-item:hover .gallery-overlay { opacity: 1; }
    .gallery-overlay-text {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 1.2rem;
      color: var(--gold-light);
    }

    /* Hair gallery — equal 3x2 */
    #hair-panel .gallery-grid {
      grid-template-rows: repeat(2, 280px);
    }
    #hair-panel .gallery-item:nth-child(1) {
      grid-row: auto;
    }

    /* ── REVIEWS SECTION ── */
    #reviews {
      padding: 110px 60px;
      background: var(--cream);
      position: relative;
      overflow: hidden;
    }
    #reviews::before {
      content: '✦';
      position: absolute;
      font-size: 18rem;
      color: rgba(201,168,76,.04);
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
      font-family: 'Cinzel', serif;
      letter-spacing: .1em;
    }
    .reviews-header { text-align: center; margin-bottom: 70px; }

    .reviews-stars-overall {
      display: flex; align-items: center; justify-content: center; gap: 12px;
      margin-top: 16px;
    }
    .stars-big {
      color: var(--gold);
      font-size: 1.5rem;
      letter-spacing: .1em;
    }
    .rating-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem; font-weight: 300;
      color: var(--deep);
    }
    .rating-count {
      font-family: 'Cinzel', serif;
      font-size: .65rem; letter-spacing: .2em;
      color: var(--text-light);
      text-transform: uppercase;
    }

    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
      max-width: 1200px;
      margin: 0 auto 50px;
    }

    .review-card {
      background: #fff;
      border: 1px solid rgba(201,168,76,.18);
      padding: 36px 32px;
      position: relative;
      transition: border-color .35s, transform .35s, box-shadow .35s;
    }
    .review-card:hover {
      border-color: rgba(201,168,76,.45);
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(201,168,76,.1);
    }
    .review-card::before {
      content: '\201C';
      position: absolute;
      top: 20px; left: 26px;
      font-family: 'Cormorant Garamond', serif;
      font-size: 4rem;
      color: rgba(201,168,76,.2);
      line-height: 1;
    }

    .review-stars {
      color: var(--gold);
      font-size: .9rem;
      letter-spacing: .1em;
      margin-bottom: 16px;
    }
    .review-text {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1.08rem;
      line-height: 1.8;
      color: var(--text);
      margin-bottom: 24px;
    }
    .review-footer {
      display: flex; align-items: center; gap: 14px;
      border-top: 1px solid rgba(201,168,76,.15);
      padding-top: 20px;
    }
    .review-avatar {
      width: 42px; height: 42px; border-radius: 50%;
      background: linear-gradient(135deg, var(--gold), var(--rose));
      display: flex; align-items: center; justify-content: center;
      font-family: 'Cinzel', serif;
      font-size: .85rem;
      color: #fff;
      flex-shrink: 0;
    }
    .review-name {
      font-family: 'Cinzel', serif;
      font-size: .72rem; letter-spacing: .15em;
      color: var(--deep);
      text-transform: uppercase;
    }
    .review-date {
      font-size: .78rem;
      color: var(--text-light);
      margin-top: 3px;
    }

    .reviews-google-link {
      text-align: center;
      margin-top: 14px;
    }
    .reviews-google-link a {
      font-family: 'Cinzel', serif;
      font-size: .72rem; letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      border-bottom: 1px solid rgba(201,168,76,.35);
      padding-bottom: 2px;
      transition: color .3s, border-color .3s;
    }
    .reviews-google-link a:hover {
      color: var(--rose);
      border-color: var(--rose);
    }

    /* ── LOCATION SECTION ── */
    #location {
      padding: 110px 60px;
      background: linear-gradient(135deg, var(--deep) 0%, var(--deep2) 100%);
    }
    .location-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
    }
    .location-text .section-title { color: var(--cream); }
    .location-text .section-desc { color: rgba(255,255,255,.6); max-width: none; }

    .location-details {
      margin-top: 40px;
      display: flex; flex-direction: column; gap: 22px;
    }
    .location-detail-item {
      display: flex; align-items: flex-start; gap: 16px;
    }
    .location-detail-icon {
